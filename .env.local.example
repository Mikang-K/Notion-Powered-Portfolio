# Notion Integration Token
# 노션 설정 > 연결 > 새 API 통합에서 발급
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Projects Database ID
# 프로젝트 데이터베이스 URL에서 32자리 ID만 추출: notion.so/[workspace]/[DATABASE_ID]?v=...
NOTION_PROJECTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) 비공개 페이지 접근 시에만 필요
# 노션 웹앱 로그인 후 브라우저 개발자도구 → Application → Cookies → token_v2 값
NOTION_TOKEN_V2=

# On-demand Revalidation 시크릿 키 (임의의 문자열로 설정)
# POST /api/revalidate?secret=<이 값> 호출 시 즉시 캐시 갱신
REVALIDATE_SECRET=your_secret_key_here
